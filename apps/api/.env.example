# Database
DATABASE_URL=postgresql://user:password@localhost:5432/smartbite

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Recipe + Nutrition APIs
USDA_API_KEY=your-key   # free at https://fdc.nal.usda.gov/api-guide.html
SPOONACULAR_API_KEY=your-key
EDAMAM_APP_ID=your-id
EDAMAM_APP_KEY=your-key

# Grocery Pricing APIs
MEALME_API_KEY=your-key
KROGER_CLIENT_ID=your-id
KROGER_CLIENT_SECRET=your-secret

# Infrastructure
REDIS_HOST=localhost
REDIS_PORT=6379

# Payments
REVENUECAT_WEBHOOK_SECRET=your-secret

# Error tracking
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_RELEASE=0.0.1

# App
NODE_ENV=development
PORT=3000
